---
// ContactForm — interactive form with client-side validation
// Extracted from ContactSection.astro static HTML
---

<div class="contact-form-card nb-card">
  <div class="form-header">
    <span class="form-label">ENVIAR MENSAJE</span>
  </div>
  <div class="form-body">
    <form id="contact-form" novalidate>
      <div class="form-fields">
        <div class="form-field">
          <label class="field-label" for="contact-name">Tu nombre</label>
          <input
            type="text"
            id="contact-name"
            name="name"
            class="field-input"
            placeholder="John Doe"
            required
          />
          <span class="field-error" data-error="name" role="alert"></span>
        </div>
        <div class="form-field">
          <label class="field-label" for="contact-email">Email</label>
          <input
            type="email"
            id="contact-email"
            name="email"
            class="field-input"
            placeholder="john@company.com"
            required
          />
          <span class="field-error" data-error="email" role="alert"></span>
        </div>
        <div class="form-field">
          <span class="field-label" id="subject-group-label"
            >¿De qué se trata?</span
          >
          <div
            class="field-options"
            role="radiogroup"
            aria-labelledby="subject-group-label"
          >
            <label class="field-option">
              <input type="radio" name="subject" value="Proyecto freelance" />
              <span>Proyecto freelance</span>
            </label>
            <label class="field-option">
              <input type="radio" name="subject" value="Trabajo full-time" />
              <span>Trabajo full-time</span>
            </label>
            <label class="field-option">
              <input type="radio" name="subject" value="Colaboración" />
              <span>Colaboración</span>
            </label>
            <label class="field-option">
              <input type="radio" name="subject" value="Solo saludar" />
              <span>Solo saludar</span>
            </label>
          </div>
          <span class="field-error" data-error="subject" role="alert"></span>
        </div>
        <div class="form-field">
          <label class="field-label" for="contact-message">Mensaje</label>
          <textarea
            id="contact-message"
            name="message"
            class="field-input field-textarea"
            placeholder="Cuéntame sobre tu proyecto..."
            rows="4"
            required></textarea>
          <span class="field-error" data-error="message" role="alert"></span>
        </div>
      </div>
      <button
        class="nb-btn nb-btn-dark form-submit"
        type="submit"
        id="contact-submit"
        style="width: 100%; justify-content: center; margin-top: 20px;"
      >
        Enviar Mensaje &rarr;
      </button>
    </form>
    <div
      id="form-status"
      class="form-status"
      style="display: none;"
      role="alert"
      aria-live="polite"
    >
    </div>
  </div>
</div>

<style>
  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .field-error {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--coral);
    min-height: 16px;
    display: block;
  }

  .field-input.invalid {
    border-color: var(--coral);
    box-shadow: 3px 3px 0 var(--coral);
  }

  .form-status {
    margin-top: 16px;
    padding: 12px 16px;
    font-family: var(--font-mono);
    font-size: 13px;
    border: 2px solid;
  }

  .form-status.success {
    background: var(--lime);
    border-color: var(--black);
    color: var(--black);
  }

  .form-status.error {
    background: #fecaca;
    border-color: var(--coral);
    color: var(--coral);
  }

  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>

<script>
  import * as FingerprintJS from "@fingerprintjs/fingerprintjs";

  const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  // Device fingerprinting for rate limiting
  // We load FingerprintJS lazily when user interacts with form
  let fpPromise: Promise<{ visitorId: string }> | null = null;

  function initFingerprint(): Promise<{ visitorId: string }> {
    if (!fpPromise) {
      fpPromise = FingerprintJS.load()
        .then((fp) => fp.get())
        .then((result) => ({ visitorId: result.visitorId }))
        .catch(() => ({
          visitorId: "fallback-" + Math.random().toString(36).slice(2),
        }));
    }
    return fpPromise;
  }

  interface FormData {
    name: string;
    email: string;
    subject: string;
    message: string;
  }

  interface ValidationError {
    field: string;
    message: string;
  }

  function validate(data: FormData): ValidationError[] {
    const errors: ValidationError[] = [];

    if (!data.name.trim()) {
      errors.push({ field: "name", message: "El nombre es requerido" });
    }

    if (!data.email.trim()) {
      errors.push({ field: "email", message: "El email es requerido" });
    } else if (!EMAIL_REGEX.test(data.email)) {
      errors.push({ field: "email", message: "Email inválido" });
    }

    if (!data.subject) {
      errors.push({
        field: "subject",
        message: "Selecciona una opción",
      });
    }

    if (!data.message.trim()) {
      errors.push({ field: "message", message: "El mensaje es requerido" });
    }

    return errors;
  }

  function clearErrors(): void {
    document.querySelectorAll(".field-error").forEach((el) => {
      el.textContent = "";
    });
    document.querySelectorAll(".field-input.invalid").forEach((el) => {
      el.classList.remove("invalid");
    });
  }

  function showErrors(errors: ValidationError[]): void {
    errors.forEach(({ field, message }) => {
      const errorEl = document.querySelector(`[data-error="${field}"]`);
      if (errorEl) errorEl.textContent = message;

      // Mark input as invalid
      const input = document.querySelector(
        `[name="${field}"]`,
      ) as HTMLInputElement | null;
      if (input && input.classList) {
        input.classList.add("invalid");
      }
    });
  }

  function showStatus(type: "success" | "error", message: string): void {
    const statusEl = document.getElementById("form-status");
    if (!statusEl) return;
    statusEl.className = `form-status ${type}`;
    statusEl.textContent = message;
    statusEl.style.display = "block";
  }

  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById(
    "contact-submit",
  ) as HTMLButtonElement;

  form?.addEventListener("submit", async (e: Event) => {
    e.preventDefault();
    clearErrors();

    const formData = new FormData(form);
    const data: FormData = {
      name: (formData.get("name") as string) || "",
      email: (formData.get("email") as string) || "",
      subject: (formData.get("subject") as string) || "",
      message: (formData.get("message") as string) || "",
    };

    const errors = validate(data);
    if (errors.length > 0) {
      showErrors(errors);
      return;
    }

    // Loading state
    submitBtn.disabled = true;
    submitBtn.textContent = "Enviando...";
    const statusEl = document.getElementById("form-status");
    if (statusEl) statusEl.style.display = "none";

    try {
      // Get device fingerprint for rate limiting
      const fp = await initFingerprint();

      const response = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          ...data,
          fingerprint: fp.visitorId,
        }),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        showStatus("success", "Mensaje enviado correctamente.");
        form.reset();
      } else {
        const msg =
          result.details?.join(", ") ||
          result.error ||
          "Error al enviar el mensaje.";
        showStatus("error", msg);
      }
    } catch {
      showStatus("error", "Error de conexión. Intenta de nuevo.");
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = "Enviar Mensaje &rarr;";
    }
  });
</script>
