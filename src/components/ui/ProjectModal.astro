---
import type { Project } from "../../data/types";
---

<div id="project-modal" class="modal-overlay hidden" aria-hidden="true">
  <div
    class="modal-dialog nb-card"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
  >
    {/* macOS Window Controls Row */}
    <div class="modal-header">
      <div class="mac-controls">
        <button id="modal-close" class="mac-btn close" aria-label="Close modal"
        ></button>
        <button class="mac-btn minimize" aria-hidden="true" disabled></button>
        <button class="mac-btn maximize" aria-hidden="true" disabled></button>
      </div>
      <div class="modal-title-bar" id="modal-title-bar">Proyecto</div>
    </div>

    <div class="modal-content">
      <div class="modal-image-container">
        <img
          id="modal-image"
          src=""
          alt="Project Image"
          class="modal-image"
          loading="lazy"
        />
      </div>

      <div class="modal-body">
        <div class="modal-top-info">
          <span id="modal-number" class="project-num"></span>
          <span id="modal-status" class="project-status"></span>
        </div>

        <h2 id="modal-title" class="project-title"></h2>
        <p id="modal-subtitle" class="project-subtitle"></p>
        <p id="modal-desc" class="project-desc detail-desc"></p>

        <div class="modal-section">
          <h3>Logros / Features</h3>
          <ul id="modal-highlights" class="modal-highlights-list">
            {/* Populated via JS */}
          </ul>
        </div>

        <div class="modal-section">
          <h3>Tech Stack</h3>
          <div id="modal-tags" class="project-tags">
            {/* Populated via JS */}
          </div>
        </div>

        <div class="modal-footer">
          <a
            id="modal-action-btn"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="nb-btn nb-btn-dark modal-btn"
          >
            Visitar Proyecto ↗
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Modal Overlay */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(
      245,
      240,
      232,
      0.2
    ); /* Semi-transparent var(--white) equivalent */
    backdrop-filter: blur(8px);
    z-index: 9900; /* Below custom cursor (9999) */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;

    /* Reveal Animation defaults */
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
    cursor: none; /* Inherit neo-brutalism custom cursor */
  }

  .modal-overlay * {
    cursor: none; /* Ensure all children also inherit custom cursor */
  }

  .modal-overlay.active {
    opacity: 1;
    pointer-events: all;
  }

  /* Modal Dialog (Neo-Brutalism & macOS) */
  .modal-dialog {
    background: var(--bg-primary, var(--white));
    width: 100%;
    max-width: 800px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;

    /* Initial state for "Genie" effect (sucked into dock) */
    transform-origin: 50% 100%;
    transform: translateY(60vh) scale(0.1);
    opacity: 0;
    border-radius: 20px; /* Slight curve to simulate warp */
    transition:
      transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.2),
      opacity 0.4s ease,
      border-radius 0.5s ease;
  }

  .modal-overlay.active .modal-dialog {
    transform: translateY(0) scale(1);
    opacity: 1;
    border-radius: 0; /* Snaps back to neo-brutalist square edges */
  }

  /* Header / macOS bar */
  .modal-header {
    border-bottom: 3px solid var(--text-main);
    padding: 1rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--bg-alt);
    position: relative;
  }

  @media (min-width: 768px) {
    .modal-header {
      padding: 0.75rem 1rem;
      align-items: center;
    }
  }

  .mac-controls {
    display: flex;
    gap: 0.5rem;
    z-index: 10;
    margin-top: 0.1rem;
  }

  @media (min-width: 768px) {
    .mac-controls {
      margin-top: 0;
    }
  }

  .mac-btn {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid var(--text-main);
    cursor: pointer;
    padding: 0;
    transition: transform 0.2s;
  }

  .mac-btn.minimize,
  .mac-btn.maximize {
    display: none;
  }

  @media (min-width: 768px) {
    .mac-btn {
      width: 14px;
      height: 14px;
    }
    .mac-btn.minimize,
    .mac-btn.maximize {
      display: block;
    }
  }

  .mac-btn:hover:not([disabled]) {
    transform: scale(1.1);
  }

  .mac-btn[disabled] {
    cursor: default;
    opacity: 0.7;
  }

  .mac-btn.close {
    background-color: #ff5f56;
  }
  .mac-btn.minimize {
    background-color: #ffbd2e;
  }
  .mac-btn.maximize {
    background-color: #27c93f;
  }

  .modal-title-bar {
    flex: 1;
    text-align: center;
    padding-right: 38px; /* Offset the left controls space */
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    pointer-events: none;
    line-height: 1.4;
    word-break: break-word;
  }

  @media (min-width: 768px) {
    .modal-title-bar {
      position: absolute;
      left: 0;
      right: 0;
      padding-right: 0;
      text-align: center;
    }
  }

  /* Content area */
  .modal-content {
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .modal-content {
      flex-direction: row;
    }
  }

  .modal-image-container {
    border-bottom: 3px solid var(--text-main);
    background: #000;
    height: 240px;
    display: flex;
  }

  @media (min-width: 768px) {
    .modal-image-container {
      border-bottom: none;
      border-right: 3px solid var(--text-main);
      width: 45%;
      min-height: auto;
    }
  }

  .modal-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .modal-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .modal-top-info {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: -0.5rem;
  }

  .detail-desc {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .modal-section h3 {
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .modal-section h3::before {
    content: "→";
    color: var(--color-accent, var(--text-main));
  }

  .modal-highlights-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .modal-highlights-list li {
    display: flex;
    gap: 0.5rem;
    font-size: 0.95rem;
    align-items: flex-start;
  }

  .modal-highlights-list li::before {
    content: "✓";
    font-weight: bold;
    color: var(--text-main);
  }

  .modal-footer {
    margin-top: auto;
    padding-top: 1.5rem;
    border-top: 3px dashed var(--text-main);
  }

  .modal-btn {
    width: 100%;
    display: block;
    text-align: center;
    font-size: 1rem;
    padding: 1rem;
  }

  .modal-btn.private-repo {
    background: var(--bg-alt);
    color: var(--text-main);
    cursor: not-allowed;
    opacity: 0.8;
  }

  .modal-btn.private-repo:hover {
    transform: none;
    box-shadow: 4px 4px 0px var(--text-main);
  }
</style>

<script>
  // Project Modal Logic
  document.addEventListener("DOMContentLoaded", () => {
    const modal = document.getElementById("project-modal");
    if (!modal) return;

    const closeBtn = document.getElementById("modal-close");
    const dialog = modal.querySelector(".modal-dialog");

    // UI Elements
    const els = {
      image: document.getElementById("modal-image") as HTMLImageElement,
      number: document.getElementById("modal-number"),
      status: document.getElementById("modal-status"),
      title: document.getElementById("modal-title"),
      subtitle: document.getElementById("modal-subtitle"),
      desc: document.getElementById("modal-desc"),
      highlights: document.getElementById("modal-highlights"),
      tags: document.getElementById("modal-tags"),
      actionBtn: document.getElementById(
        "modal-action-btn",
      ) as HTMLAnchorElement,
      titleBar: document.getElementById("modal-title-bar"),
    };

    // Close logic
    const closeModal = () => {
      modal.classList.remove("active");
      // Reset after animation
      setTimeout(() => {
        modal.classList.add("hidden");
      }, 500); // matches CSS transition time
    };

    closeBtn?.addEventListener("click", closeModal);

    // Close on click outside
    modal.addEventListener("click", (e) => {
      if (e.target === modal) {
        closeModal();
      }
    });

    // Close on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modal.classList.contains("active")) {
        closeModal();
      }
    });

    // Listen for open events requested by project cards
    document.addEventListener("openProjectModal", ((e: CustomEvent | Event) => {
      const customEvent = e as CustomEvent;
      const p = customEvent.detail;
      if (!p) return;

      // Populate data
      if (els.image) {
        // Fallback placeholder if no image
        els.image.src =
          p.image ||
          "https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=800&q=80";
        els.image.alt = p.title;
      }

      if (els.number) els.number.textContent = p.number;
      if (els.status) els.status.textContent = p.status;
      if (els.title) els.title.textContent = p.title;
      if (els.subtitle) els.subtitle.textContent = p.subtitle;
      if (els.desc) els.desc.textContent = p.description;
      if (els.titleBar) els.titleBar.textContent = `[${p.number}] ${p.title}`;

      // Update accent color variable for the modal dialog
      if (dialog) {
        (dialog as HTMLElement).style.setProperty(
          "--color-accent",
          p.accentColor || "var(--text-main)",
        );
      }

      // Highlights
      if (els.highlights) {
        els.highlights.innerHTML = "";
        const hlContainer = els.highlights;
        (p.highlights || []).forEach((h: string) => {
          const li = document.createElement("li");
          li.textContent = h;
          hlContainer.appendChild(li);
        });
      }

      // Tags
      if (els.tags) {
        els.tags.innerHTML = "";
        const tagsContainer = els.tags;
        (p.tags || []).forEach((t: string) => {
          const span = document.createElement("span");
          span.className = "project-tag";
          span.textContent = t;
          tagsContainer.appendChild(span);
        });
      }

      // Action Button
      if (els.actionBtn) {
        if (p.isPrivate) {
          els.actionBtn.textContent = "Proyecto privado";
          els.actionBtn.href = "#";
          els.actionBtn.className = "nb-btn nb-btn-dark modal-btn private-repo";
          els.actionBtn.onclick = (ev) => ev.preventDefault();
        } else {
          els.actionBtn.textContent = "Visitar Proyecto ↗";
          els.actionBtn.href = p.url || p.links?.demo || p.links?.github || "#";
          els.actionBtn.className = "nb-btn nb-btn-dark modal-btn";
          els.actionBtn.onclick = null;
        }
      }

      // Show modal
      modal.classList.remove("hidden");
      // Small delay to allow display block to apply before animating opacity
      setTimeout(() => {
        modal.classList.add("active");
      }, 10);
    }) as EventListener);
  });
</script>
