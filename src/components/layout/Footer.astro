---
import { footerData, socialLinks } from '../../data/navigation';
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-left">
        <span class="footer-logo" aria-hidden="true">{footerData.logo}</span>
        <p>Construyendo el futuro,<br />un agente a la vez.</p>
      </div>
      <nav class="footer-links" aria-label="Redes sociales">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith('mailto') ? undefined : '_blank'}
            rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            class="footer-link"
            aria-label={`${link.label}${link.href.startsWith('mailto') ? '' : ' (abre en nueva pestaña)'}`}
          >
            {link.label} ↗
          </a>
        ))}
      </nav>
      <div class="footer-right">
        <div class="footer-badge" aria-hidden="true">
          <span>{footerData.copyright}</span>
        </div>
        <p class="footer-built">{footerData.builtWith}</p>
      </div>
    </div>
  </div>
</footer>
